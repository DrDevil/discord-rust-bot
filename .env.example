# =============================================================================
# Rust+ Discord Bot — environment configuration (Phase 1)
# Copy to ".env" and fill in real values. NEVER commit your real .env.
# All secrets are read from the environment (CLAUDE.md §8). No hardcoded tokens.
# =============================================================================

# --- Discord ---------------------------------------------------------------
# Bot token from the Discord Developer Portal (Bot -> Token).
DISCORD_TOKEN=
# The numeric ID of the guild (server) where slash commands are registered.
DISCORD_GUILD_ID=
# The numeric channel ID where alerts are posted.
ALERT_CHANNEL_ID=

# --- Rust+ pairing (obtained via the external Node tool, see README) -------
# IP / port reported when you pair the server in-game.
RUST_SERVER_IP=
RUST_SERVER_PORT=
# Your 64-bit Steam ID (the Rust+ "playerId"). Must be an integer.
RUST_STEAM_ID=
# The Rust+ pairing "playerToken". Must be an integer. Treat like a password.
RUST_PLAYER_TOKEN=

# Optional stable identifier for this server in logs/persistence.
# Defaults to "<ip>:<port>" if left blank.
RUST_SERVER_ID=

# --- Encryption at rest ----------------------------------------------------
# Fernet key used to encrypt the player token stored in SQLite.
# Generate one with:  python -m rustbot.genkey
# Keep this OUT of any database backups (see README security notes).
FERNET_KEY=

# --- Behaviour -------------------------------------------------------------
# Seconds between server/team status polls.
POLL_INTERVAL=30
# Path to the SQLite database file.
DATABASE_PATH=data/rustbot.db
# Logging level: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO
# Set to "true" to log raw Rust+ protobuf traffic at DEBUG.
# WARNING: raw traffic may contain sensitive data (positions, names). Off by default.
DEBUG_PROTOBUF=false
